//@version=6
indicator("🐋 Whale Trap Detector PRO", overlay=true, max_labels_count=500, max_lines_count=500, max_boxes_count=500)

// ═══════════════════════════════════════════════════════════════
//  INPUTS
// ═══════════════════════════════════════════════════════════════

// — Whale Trap —
grp1         = "🐋 Whale Trap"
volMulti     = input.float(2.0, "Volume Multiplier (whale)",  minval=1.0, maxval=10.0, step=0.1, group=grp1)
trapLookback = input.int(10,    "Trap Lookback",              minval=3,   maxval=50,             group=grp1)
atrMult      = input.float(0.8, "ATR Filter Multiplier",      minval=0.1, maxval=5.0,  step=0.1, group=grp1)

// — Bollinger Bands —
grp2     = "📊 Bollinger Bands"
bbLength = input.int(20,      "Length",     minval=1,                                  group=grp2)
maType   = input.string("SMA","Basis MA",   options=["SMA","EMA","SMMA (RMA)","WMA","VWMA"], group=grp2)
src      = input(close,       "Source",                                                group=grp2)
mult     = input.float(2.0,   "StdDev",     minval=0.001, maxval=50,                  group=grp2)
bbOffset = input.int(0,       "Offset",     minval=-500,  maxval=500, display=display.none, group=grp2)

// — Trend EMAs —
grp3     = "📈 Trend Filter (EMA)"
showEMAs = input.bool(true, "Show EMAs",    group=grp3)
emaFast  = input.int(50,    "Fast EMA",     minval=1, group=grp3)
emaSlow  = input.int(200,   "Slow EMA",     minval=2, group=grp3)

// — RSI —
grp4    = "📉 RSI + Divergence"
rsiLen  = input.int(14,    "RSI Length",   minval=2,            group=grp4)
rsiOB   = input.int(70,    "Overbought",   minval=50, maxval=100, group=grp4)
rsiOS   = input.int(30,    "Oversold",     minval=0,  maxval=50,  group=grp4)
showDiv = input.bool(true,  "Show Divergences",                  group=grp4)

// — VWAP —
grp5     = "💹 VWAP"
showVWAP = input.bool(true, "Show VWAP", group=grp5)

// — Order Blocks —
grp6   = "🏦 Order Blocks"
showOB = input.bool(true,  "Show Order Blocks",     group=grp6)
obLB   = input.int(3,      "Lookback",  minval=1, maxval=10,     group=grp6)
obAtrM = input.float(1.5,  "ATR Multiplier (force)", minval=0.5, maxval=5.0, step=0.1, group=grp6)

// — Fair Value Gaps —
grp7    = "⚡ Fair Value Gaps"
showFVG = input.bool(true, "Show FVG", group=grp7)

// — Confluence Score —
grp8         = "🎯 Score de Confluence"
minBullScore = input.int(4, "Score min BULL", minval=1, maxval=7, group=grp8)
minBearScore = input.int(4, "Score min BEAR", minval=1, maxval=7, group=grp8)

// — Dashboard —
grp9     = "📋 Dashboard"
showDash = input.bool(true, "Afficher Dashboard", group=grp9)
dashPos  = input.string("Top Right", "Position", options=["Top Right","Top Left","Bottom Right","Bottom Left"], group=grp9)

// ═══════════════════════════════════════════════════════════════
//  BASE
// ═══════════════════════════════════════════════════════════════
volAvg = ta.sma(volume, 20)
atr    = ta.atr(14)

// ═══════════════════════════════════════════════════════════════
//  MODULE 1 — WHALE TRAP (original amélioré)
// ═══════════════════════════════════════════════════════════════
whaleVolume  = volume > volAvg * volMulti
hiLvl        = ta.highest(high, trapLookback)[1]
loLvl        = ta.lowest(low,  trapLookback)[1]
bullTrap     = high > hiLvl and close < hiLvl
bearTrap     = low  < loLvl and close > loLvl
validMove    = (high - low) > atr * atrMult
manipulation = (bullTrap or bearTrap) and validMove
whaleTrap    = whaleVolume and manipulation

// ═══════════════════════════════════════════════════════════════
//  MODULE 2 — BOLLINGER BANDS (original + Squeeze)
// ═══════════════════════════════════════════════════════════════
ma(source, length, _type) =>
    switch _type
        "SMA"        => ta.sma(source, length)
        "EMA"        => ta.ema(source, length)
        "SMMA (RMA)" => ta.rma(source, length)
        "WMA"        => ta.wma(source, length)
        "VWMA"       => ta.vwma(source, length)

basis      = ma(src, bbLength, maType)
dev        = mult * ta.stdev(src, bbLength)
upper      = basis + dev
lower      = basis - dev
bbWidth    = upper - lower
bbWidthAvg = ta.sma(bbWidth, 20)
bbSqueeze  = bbWidth < bbWidthAvg * 0.75  // compression forte → explosion imminente

// ═══════════════════════════════════════════════════════════════
//  MODULE 3 — TENDANCE (EMA 50/200)
// ═══════════════════════════════════════════════════════════════
ema50       = ta.ema(close, emaFast)
ema200      = ta.ema(close, emaSlow)
trendUp     = ema50 > ema200
goldenCross = ta.crossover(ema50, ema200)
deathCross  = ta.crossunder(ema50, ema200)

// ═══════════════════════════════════════════════════════════════
//  MODULE 4 — RSI + DIVERGENCES
// ═══════════════════════════════════════════════════════════════
rsi           = ta.rsi(close, rsiLen)
rsiOverbought = rsi >= rsiOB
rsiOversold   = rsi <= rsiOS

// Divergence haussière : prix = plus bas local, RSI ne confirme pas
bullDiv = showDiv and
          (low  <= ta.lowest(low[1],  5)) and
          (rsi  >  ta.lowest(rsi[1],  5) + 2) and
          rsi   <  (rsiOS + 15)

// Divergence baissière : prix = plus haut local, RSI ne confirme pas
bearDiv = showDiv and
          (high >= ta.highest(high[1], 5)) and
          (rsi  <  ta.highest(rsi[1],  5) - 2) and
          rsi   >  (rsiOB - 15)

// ═══════════════════════════════════════════════════════════════
//  MODULE 5 — VWAP
// ═══════════════════════════════════════════════════════════════
vwap      = ta.vwap(hlc3)
aboveVWAP = close > vwap

// ═══════════════════════════════════════════════════════════════
//  MODULE 6 — ORDER BLOCKS (Smart Money)
// ═══════════════════════════════════════════════════════════════
// Bullish OB : bougie baissière il y a [obLB] bougies → fort mouvement haussier maintenant
bullOB = showOB and
         (close[obLB] < open[obLB]) and
         (close > open) and
         (high - low) > atr * obAtrM and
         volume > volAvg * 1.3

// Bearish OB : bougie haussière il y a [obLB] bougies → fort mouvement baissier maintenant
bearOB = showOB and
         (close[obLB] > open[obLB]) and
         (close < open) and
         (high - low) > atr * obAtrM and
         volume > volAvg * 1.3

// ═══════════════════════════════════════════════════════════════
//  MODULE 7 — FAIR VALUE GAPS
// ═══════════════════════════════════════════════════════════════
// Bullish FVG : low[0] > high[2] → gap non comblé entre les deux bougies
bullFVG = showFVG and (low  > high[2]) and ((high[1] - low[1]) > atr * 1.2)
// Bearish FVG : high[0] < low[2] → gap non comblé entre les deux bougies
bearFVG = showFVG and (high < low[2])  and ((high[1] - low[1]) > atr * 1.2)

// ═══════════════════════════════════════════════════════════════
//  MODULE 8 — SCORE DE CONFLUENCE (0 à 7)
// ═══════════════════════════════════════════════════════════════
bullScore = (
    (trendUp ? 1 : 0) +
    (aboveVWAP ? 1 : 0) +
    (rsiOversold ? 1 : 0) +
    (bullDiv ? 2 : 0) +
    (bearTrap ? 1 : 0) +
    (whaleVolume ? 1 : 0)
)

bearScore = (
    (not trendUp ? 1 : 0) +
    (not aboveVWAP ? 1 : 0) +
    (rsiOverbought ? 1 : 0) +
    (bearDiv ? 2 : 0) +
    (bullTrap ? 1 : 0) +
    (whaleVolume ? 1 : 0)
)
strongBull = bullScore >= minBullScore
strongBear = bearScore >= minBearScore

// ═══════════════════════════════════════════════════════════════
//  AFFICHAGE — BOLLINGER BANDS
// ═══════════════════════════════════════════════════════════════
bbColor = bbSqueeze ? color.rgb(255, 200, 0) : color.rgb(117, 0, 212)

plot(basis, "Basis", color=color.white, offset=bbOffset)

p1 = plot(
    upper,
    "Upper",
    color=bbColor,
    offset=bbOffset,
    linewidth=1
)

p2 = plot(
    lower,
    "Lower",
    color=bbColor,
    offset=bbOffset,
    linewidth=1
)

fill(
    p1,
    p2,
    title="BB Fill",
    color=color.new(color.white, 95)
)

// ═══════════════════════════════════════════════════════════════
//  AFFICHAGE — EMAs
// ═══════════════════════════════════════════════════════════════
plot(showEMAs ? ema50  : na, "EMA Fast", color=color.rgb(0, 200, 255), linewidth=1)
plot(showEMAs ? ema200 : na, "EMA Slow", color=color.rgb(255, 165, 0), linewidth=2)

if goldenCross
    label.new(bar_index, low,  "✨ Golden Cross", color=color.rgb(255,215,0), textcolor=color.black, style=label.style_label_up,   size=size.small)
if deathCross
    label.new(bar_index, high, "💀 Death Cross",  color=color.rgb(80,0,0),   textcolor=color.white, style=label.style_label_down, size=size.small)

// ═══════════════════════════════════════════════════════════════
//  AFFICHAGE — VWAP
// ═══════════════════════════════════════════════════════════════
plot(showVWAP ? vwap : na, "VWAP", color=color.rgb(255, 255, 100), linewidth=1, style=plot.style_stepline)

// ═══════════════════════════════════════════════════════════════
//  AFFICHAGE — WHALE TRAP (labels originaux)
// ═══════════════════════════════════════════════════════════════
if whaleVolume and bullTrap and validMove
    label.new(bar_index, high, "🐋 Whale Bull Trap", color=color.rgb(206,0,0),   textcolor=color.white, style=label.style_label_down)
else if whaleVolume and bearTrap and validMove
    label.new(bar_index, low,  "🐋 Whale Bear Trap", color=color.rgb(0,112,4),   textcolor=color.white, style=label.style_label_up)
else if whaleVolume
    label.new(bar_index, low,  "🐋 Whale Volume",    color=color.rgb(0,112,4),   textcolor=color.white, style=label.style_label_up)
else if bullTrap and validMove
    label.new(bar_index, high, "⚠️ Bull Trap",        color=color.rgb(255,115,0), textcolor=color.white, style=label.style_label_down)
else if bearTrap and validMove
    label.new(bar_index, low,  "⚠️ Bear Trap",        color=color.rgb(255,115,0), textcolor=color.white, style=label.style_label_up)

// ═══════════════════════════════════════════════════════════════
//  AFFICHAGE — DIVERGENCES RSI
// ═══════════════════════════════════════════════════════════════
if bullDiv
    label.new(bar_index, low,  "📈 Bull Div", color=color.rgb(0,180,100),  textcolor=color.white, style=label.style_label_up,   size=size.small)
if bearDiv
    label.new(bar_index, high, "📉 Bear Div", color=color.rgb(180,0,100),  textcolor=color.white, style=label.style_label_down, size=size.small)

// ═══════════════════════════════════════════════════════════════
//  AFFICHAGE — ORDER BLOCKS (rectangles)
// ═══════════════════════════════════════════════════════════════
if bullOB
    box.new(bar_index - obLB, high[obLB], bar_index + 5, low[obLB],
            bgcolor=color.rgb(0,255,100,85), border_color=color.rgb(0,200,80), border_width=1)
if bearOB
    box.new(bar_index - obLB, high[obLB], bar_index + 5, low[obLB],
            bgcolor=color.rgb(255,0,80,85),  border_color=color.rgb(200,0,60), border_width=1)

// ═══════════════════════════════════════════════════════════════
//  AFFICHAGE — FAIR VALUE GAPS (rectangles)
// ═══════════════════════════════════════════════════════════════
if bullFVG
    box.new(bar_index - 2, low, bar_index + 5, high[2],
            bgcolor=color.rgb(0,200,255,88), border_color=color.rgb(0,180,220,60))
if bearFVG
    box.new(bar_index - 2, low[2], bar_index + 5, high,
            bgcolor=color.rgb(255,100,0,88), border_color=color.rgb(220,80,0,60))

// ═══════════════════════════════════════════════════════════════
//  AFFICHAGE — STRONG SIGNALS (confluence)
// ═══════════════════════════════════════════════════════════════
if strongBull
    label.new(bar_index, low,  "🚀 BUY  " + str.tostring(bullScore) + "/7",
              color=color.rgb(0,200,80),  textcolor=color.white, style=label.style_label_up,   size=size.normal)
if strongBear
    label.new(bar_index, high, "🔻 SELL  " + str.tostring(bearScore) + "/7",
              color=color.rgb(200,0,50), textcolor=color.white, style=label.style_label_down, size=size.normal)

// ═══════════════════════════════════════════════════════════════
//  AFFICHAGE — COULEUR DES BOUGIES (signal fort)
// ═══════════════════════════════════════════════════════════════
barcolor(strongBull ? color.rgb(0,255,120,30) : strongBear ? color.rgb(255,0,80,30) : na, title="Signal Candle Color")

// ═══════════════════════════════════════════════════════════════
//  AFFICHAGE — BB SQUEEZE BACKGROUND
// ═══════════════════════════════════════════════════════════════
bgcolor(bbSqueeze ? color.rgb(255,230,0,92) : na, title="BB Squeeze Background")

// ═══════════════════════════════════════════════════════════════
//  AFFICHAGE — DASHBOARD
// ═══════════════════════════════════════════════════════════════
dashPosition = switch dashPos
    "Top Right"    => position.top_right
    "Top Left"     => position.top_left
    "Bottom Right" => position.bottom_right
    =>                position.bottom_left

var table dash = table.new(dashPosition, 2, 10,
     bgcolor=color.rgb(10,10,30,5),
     border_color=color.rgb(60,60,100), border_width=1,
     frame_color=color.rgb(80,80,150),  frame_width=1)

if barstate.islast and showDash
    table.cell(dash, 0, 0, "🐋 WHALE TRAP PRO", text_color=color.rgb(255,215,0), text_size=size.small, bgcolor=color.rgb(20,20,50))
    table.cell(dash, 1, 0, "",                   text_color=color.white,          text_size=size.small, bgcolor=color.rgb(20,20,50))

    table.cell(dash, 0, 1, "Tendance",    text_color=color.rgb(180,180,220), text_size=size.tiny)
    table.cell(dash, 1, 1, trendUp ? "▲ BULL" : "▼ BEAR",
               text_color=trendUp ? color.rgb(0,220,80) : color.rgb(220,50,80), text_size=size.tiny)

    table.cell(dash, 0, 2, "VWAP",        text_color=color.rgb(180,180,220), text_size=size.tiny)
    table.cell(dash, 1, 2, aboveVWAP ? "Au-dessus ✅" : "En-dessous ❌",
               text_color=aboveVWAP ? color.rgb(0,220,80) : color.rgb(220,50,80), text_size=size.tiny)

    rsiLabel = rsiOverbought ? "Suracheté 🔴" : rsiOversold ? "Survendu 🟢" : "Neutre ⚪"
    rsiCol   = rsiOverbought ? color.rgb(220,50,80) : rsiOversold ? color.rgb(0,220,80) : color.gray
    table.cell(dash, 0, 3, "RSI (" + str.tostring(math.round(rsi, 1)) + ")", text_color=color.rgb(180,180,220), text_size=size.tiny)
    table.cell(dash, 1, 3, rsiLabel, text_color=rsiCol, text_size=size.tiny)

    table.cell(dash, 0, 4, "BB Squeeze",  text_color=color.rgb(180,180,220), text_size=size.tiny)
    table.cell(dash, 1, 4, bbSqueeze ? "Actif 🟡" : "Inactif",
               text_color=bbSqueeze ? color.rgb(255,200,0) : color.gray, text_size=size.tiny)

    table.cell(dash, 0, 5, "Whale Vol",   text_color=color.rgb(180,180,220), text_size=size.tiny)
    table.cell(dash, 1, 5, whaleVolume ? "OUI 🐋" : "non",
               text_color=whaleVolume ? color.rgb(0,180,220) : color.gray, text_size=size.tiny)

    table.cell(dash, 0, 6, "Manipulation",text_color=color.rgb(180,180,220), text_size=size.tiny)
    table.cell(dash, 1, 6, manipulation ? "OUI ⚠️" : "non",
               text_color=manipulation ? color.rgb(255,140,0) : color.gray, text_size=size.tiny)

    table.cell(dash, 0, 7, "Score BULL",  text_color=color.rgb(180,180,220), text_size=size.tiny)
    table.cell(dash, 1, 7, str.tostring(bullScore) + " / 7",
               text_color=bullScore >= minBullScore ? color.rgb(0,220,80) : color.gray, text_size=size.tiny)

    table.cell(dash, 0, 8, "Score BEAR",  text_color=color.rgb(180,180,220), text_size=size.tiny)
    table.cell(dash, 1, 8, str.tostring(bearScore) + " / 7",
               text_color=bearScore >= minBearScore ? color.rgb(220,50,80) : color.gray, text_size=size.tiny)

    signalLabel = strongBull ? "🚀 BUY" : strongBear ? "🔻 SELL" : "— attente"
    signalCol   = strongBull ? color.rgb(0,220,80) : strongBear ? color.rgb(220,50,80) : color.gray
    table.cell(dash, 0, 9, "Signal",      text_color=color.rgb(180,180,220), text_size=size.tiny)
    table.cell(dash, 1, 9, signalLabel,   text_color=signalCol, text_size=size.tiny)

// ═══════════════════════════════════════════════════════════════
//  ALERTES
// ═══════════════════════════════════════════════════════════════
alertcondition(whaleTrap,   "🐋 Whale Trap",      "Whale Trap détecté !")
alertcondition(strongBull,  "🚀 Signal BUY",      "Signal BUY confluent détecté !")
alertcondition(strongBear,  "🔻 Signal SELL",     "Signal SELL confluent détecté !")
alertcondition(bullDiv,     "📈 Bull Divergence", "Divergence RSI haussière !")
alertcondition(bearDiv,     "📉 Bear Divergence", "Divergence RSI baissière !")
alertcondition(goldenCross, "✨ Golden Cross",    "Golden Cross EMA détecté !")
alertcondition(deathCross,  "💀 Death Cross",     "Death Cross EMA détecté !")
alertcondition(bbSqueeze,   "🟡 BB Squeeze",      "BB Squeeze — explosion imminente !")